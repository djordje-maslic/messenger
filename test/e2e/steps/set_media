class FakeDeviceDetails implements DeviceDetails {
  FakeDeviceDetails({
    required this.newId,
    required this.newDeviceId,
    required this.newLabel,
    required this.newKind,
    this.newAudioDeviceKind,
  });

  final String newLabel;
  final MediaDeviceKind newKind;
  final String newId;
  final String newDeviceId;
  final AudioDeviceKind? newAudioDeviceKind;

  @override
  String id() => newId;

  @override
  String? groupId() => 'group_1';

  @override
  bool isFailed() => false;

  @override
  void free() {}

  @override
  String deviceId() => newDeviceId;

  @override
  MediaDeviceKind kind() => newKind;

  @override
  String label() => newLabel;

  @override
  AudioDeviceKind? audioDeviceKind() => null;
}
